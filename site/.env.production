# Produção: tudo passa pelo nginx do domínio (que manda /api/ e /media/ pro gunicorn na 8001).
# Sem isso o site cai no default http://localhost:8000 do lib/api.js e lib/authClient.js:
# - no SSR, 8000 é o Django do whey nesse EC2 → listagem vazia;
# - no navegador do visitante, localhost é a máquina dele → login/breeding quebram.
# Usar o domínio (e não 127.0.0.1:8001) também faz o build_absolute_uri das imagens gerar URL válida.
API_URL=https://palword.endrioalberton.com.br
NEXT_PUBLIC_API_URL=https://palword.endrioalberton.com.br
